  .card-outline {
    width: 323px;
    height: 204px;
    border: 2.5px dashed var(--accent);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-bg);
    transition: width 0.15s ease;
  }

  .card-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* ====== SEO CONTENT ====== */
  .seo-container { max-width: var(--container-lg); }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .steps-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--accent);
