  /* ====== FAQ ====== */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
    max-width: var(--container-lg);
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .faq-item:hover { box-shadow: var(--shadow-sm); }
  .faq-item[open] { box-shadow: var(--shadow-md); }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text-primary);
    list-style: none;
    user-select: none;
    transition: background var(--transition-fast);
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { background: var(--bg-secondary); }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform var(--transition-base);
    color: var(--text-tertiary);
  }

  .faq-item[open] .faq-chevron { transform: rotate(180deg); }

  .faq-answer { padding: 0 var(--space-5) var(--space-4); }

  .faq-answer p {
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: 0;
  }
</style>

<script>
  import { generateFullPageRulerSVG, calcMaxUnits, type RulerUnit } from '../scripts/ruler';
  import { detectDevice, onOrientationChange } from '../scripts/device-detect';
  import {
    loadCalibration,
    resetCalibration,
    autoCalibrate,
    calibrateByDiagonal,
    calibrateByCard,
    getCurrentPxPerMm,
  } from '../scripts/calibration';

  // State
  let currentUnit: RulerUnit = 'cm';
  let currentDevice = detectDevice();

  // DOM refs
  const rulerTrack = document.getElementById('ruler-track')!;
  const scrollArea = document.getElementById('ruler-scroll-area')!;
  const deviceNameEl = document.getElementById('device-name')!;
  const deviceDiagEl = document.getElementById('device-diagonal')!;
  const screenInput = document.getElementById('screen-size-input') as HTMLInputElement;
  const btnUnitCm = document.getElementById('btn-unit-cm')!;
  const btnUnitInch = document.getElementById('btn-unit-inch')!;

  // --- Auto-calibrate on first load ---
  function initCalibration() {
    const existing = loadCalibration();
    if (!existing) {
      // First visit: auto-calibrate using detected diagonal
      autoCalibrate(currentDevice.estimatedDiagonalInches);
    }
    updateDeviceCard();
  }

  function updateDeviceCard() {
    const cal = loadCalibration();
    const diag = cal?.diagonalInches || currentDevice.estimatedDiagonalInches;

    deviceNameEl.textContent = currentDevice.deviceName;
    deviceDiagEl.textContent = `· ${diag.toFixed(2)}"`;
    screenInput.value = diag.toFixed(1);

    // Update calibration status panel
    const statusText = document.getElementById('calibration-status-text');
    if (statusText) {
      const method = cal?.method || 'default';
      const labels: Record<string, string> = {
        auto: 'Automatyczna',
        diagonal: 'Ręczna (przekątna)',
        card: 'Ręczna (karta)',
        default: 'Domyślna (96 DPI)',
      };
      statusText.innerHTML = `
        <strong>Metoda:</strong> ${labels[method] || 'Automatyczna'}<br>
        <strong>Przekątna:</strong> ${diag.toFixed(1)}"<br>
        <strong>Urządzenie:</strong> ${currentDevice.deviceName}<br>
        <strong>Skala:</strong> ${getCurrentPxPerMm().toFixed(2)} px/mm
      `;
    }
  }

  // --- Render ruler ---
  function renderRuler() {
    const pxPerMm = getCurrentPxPerMm();
    // Use viewport height as base for vertical ruler (allow scrolling for more)
    const availableHeight = Math.max(window.innerHeight * 3, 2000);
    const totalUnits = calcMaxUnits(availableHeight, currentUnit, pxPerMm);

    const svg = generateFullPageRulerSVG({
      orientation: 'vertical',
      unit: currentUnit,
      pxPerMm,
      totalUnits: Math.min(totalUnits, currentUnit === 'cm' ? 50 : 20),
    });

    rulerTrack.innerHTML = svg;
  }

  // --- Initialize ---
  initCalibration();
  renderRuler();

  // --- Screen size input: recalibrate when changed ---
  screenInput.addEventListener('change', () => {
    const val = parseFloat(screenInput.value);
    if (val && val >= 3 && val <= 100) {
      calibrateByDiagonal(val);
      updateDeviceCard();
      renderRuler();
    }
  });

  // Re-detect button
  document.getElementById('btn-redetect')?.addEventListener('click', () => {
    currentDevice = detectDevice();
    autoCalibrate(currentDevice.estimatedDiagonalInches);
    updateDeviceCard();
    renderRuler();
  });

  // --- Unit toggle ---
  btnUnitCm.addEventListener('click', () => {
    currentUnit = 'cm';
    btnUnitCm.classList.add('active');
    btnUnitCm.setAttribute('aria-pressed', 'true');
    btnUnitInch.classList.remove('active');
    btnUnitInch.setAttribute('aria-pressed', 'false');
    renderRuler();
  });

  btnUnitInch.addEventListener('click', () => {
    currentUnit = 'inch';
    btnUnitInch.classList.add('active');
    btnUnitInch.setAttribute('aria-pressed', 'true');
    btnUnitCm.classList.remove('active');
    btnUnitCm.setAttribute('aria-pressed', 'false');
    renderRuler();
  });

  // --- Orientation change ---
  onOrientationChange(() => {
    currentDevice = detectDevice();
    renderRuler();
    updateDeviceCard();
  });

  // --- Credit card calibration ---
  const cardOutline = document.getElementById('card-outline') as HTMLElement;
  const cardSlider = document.getElementById('card-slider') as HTMLInputElement;

  if (cardSlider && cardOutline) {
    cardSlider.addEventListener('input', () => {
      const width = parseInt(cardSlider.value);
      cardOutline.style.width = width + 'px';
      cardOutline.style.height = Math.round(width * (53.98 / 85.6)) + 'px';
    });
  }

  document.getElementById('btn-calibrate-card')?.addEventListener('click', () => {
    if (cardSlider) {
      calibrateByCard(parseInt(cardSlider.value));
      updateDeviceCard();
      renderRuler();
    }
  });

  // --- Reset calibration ---
  document.getElementById('btn-reset-calibration')?.addEventListener('click', () => {
    resetCalibration();
    currentDevice = detectDevice();
    autoCalibrate(currentDevice.estimatedDiagonalInches);
    updateDeviceCard();
    renderRuler();
  });
</script>
