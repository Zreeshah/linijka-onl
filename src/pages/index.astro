---
import BaseLayout from '../layouts/BaseLayout.astro';

// Schema markup
const schemaWebApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Linijka online",
  "url": "https://linijka.onl",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web browser",
  "inLanguage": "pl",
  "description": "Darmowa linijka online w cm i mm. Użyj telefonu, tabletu lub komputera jako miarki.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "PLN"
  }
};

const schemaHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Jak używać linijki online",
  "description": "Instrukcja korzystania z linijki online na telefonie, tablecie lub komputerze.",
  "inLanguage": "pl",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Otwórz stronę",
      "text": "Otwórz stronę na swoim urządzeniu."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Skalibruj linijkę",
      "text": "Skalibruj linijkę, aby poprawić dokładność."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Połóż przedmiot",
      "text": "Połóż przedmiot przy skali na ekranie."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Odczytaj wynik",
      "text": "Odczytaj długość w centymetrach lub milimetrach."
    }
  ]
};

const faqItems = [
  {
    question: "Czy linijka online działa na telefonie?",
    answer: "Tak, linijka online działa na telefonie. Najlepiej używać jej w trybie poziomym i skalibrować ekran przed pomiarem."
  },
  {
    question: "Czy mogę używać linijki online bez instalacji aplikacji?",
    answer: "Tak, narzędzie działa bez instalacji aplikacji. Wystarczy otworzyć stronę w przeglądarce."
  },
  {
    question: "Dlaczego muszę skalibrować linijkę?",
    answer: "Różne ekrany mają różną gęstość pikseli, dlatego kalibracja pomaga dopasować skalę do rzeczywistego rozmiaru."
  },
  {
    question: "Czy dostępna jest linijka do druku?",
    answer: "Tak, na stronie znajduje się linijka do druku w centymetrach i milimetrach. Należy drukować ją w skali 100%."
  },
  {
    question: "Czy linijka online pokazuje milimetry?",
    answer: "Tak, linijka pokazuje centymetry i milimetry, dzięki czemu można mierzyć małe przedmioty dokładniej."
  }
];

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const allSchemas = JSON.stringify([schemaWebApp, schemaHowTo, schemaFAQ]);

const conversionData = [
  { cm: 1, mm: 10, inch: "0,39" },
  { cm: 2, mm: 20, inch: "0,79" },
  { cm: 3, mm: 30, inch: "1,18" },
  { cm: 4, mm: 40, inch: "1,57" },
  { cm: 5, mm: 50, inch: "1,97" },
  { cm: 10, mm: 100, inch: "3,94" },
  { cm: 15, mm: 150, inch: "5,91" },
  { cm: 20, mm: 200, inch: "7,87" },
  { cm: 25, mm: 250, inch: "9,84" },
  { cm: 30, mm: 300, inch: "11,81" },
  { cm: 50, mm: 500, inch: "19,69" },
];
---

<BaseLayout
  title="Linijka online 1:1 – miarka cm na telefonie i komputerze"
  description="Darmowa linijka online w cm i mm. Użyj telefonu, tabletu lub komputera jako miarki. Skalibruj ekran i mierz przedmioty online."
  schemaMarkup={allSchemas}
>
  <!-- ====== HERO SECTION ====== -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <h1>Linijka online 1:1 – miarka cm na&nbsp;ekranie</h1>
          <p class="hero-subtitle">
            Zmierz małe przedmioty bez fizycznej linijki. Użyj naszej linijki online na telefonie, tablecie lub&nbsp;komputerze.
          </p>
          <div class="hero-cta">
            <a href="#linijka" class="btn btn-primary btn-lg" id="cta-use-ruler">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M2 12h20M6 8v8M10 10v4M14 8v8M18 10v4"/>
              </svg>
              Użyj linijki online
            </a>
            <a href="/linijka-do-druku/" class="btn btn-secondary btn-lg" id="cta-print-ruler">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <polyline points="6 9 6 2 18 2 18 9"/>
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                <rect x="6" y="14" width="12" height="8"/>
              </svg>
              Pobierz linijkę do druku
            </a>
          </div>
          <p class="hero-trust">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Automatyczna kalibracja – linijka dostosowuje się do Twojego ekranu.
          </p>
        </div>
        <div class="hero-image">
          <img
            src="/images/hero.webp"
            alt="Linijka online na telefonie i komputerze"
            width="520"
            height="340"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FULL-PAGE RULER TOOL ====== -->
  <section class="ruler-section no-print" id="linijka" aria-label="Linijka online">
    <div class="ruler-hint">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>
      Przewiń w dół, aby zobaczyć pełną linijkę
    </div>

    <!-- Floating device info card -->
    <div class="ruler-device-card" id="ruler-device-card">
      <div class="device-card-header">
        <span class="device-name" id="device-name">Wykrywanie...</span>
        <span class="device-diagonal" id="device-diagonal"></span>
      </div>
      <div class="device-card-body">
        <div class="device-screen-input">
          <label for="screen-size-input" class="sr-only">Rozmiar ekranu w calach</label>
          <div class="screen-size-display">
            <span class="screen-label">Ekran</span>
            <input
              type="number"
              id="screen-size-input"
              class="screen-value-input"
              min="3"
              max="100"
              step="0.1"
              aria-label="Przekątna ekranu w calach"
            />
            <span class="screen-unit">cali</span>
          </div>
          <span class="device-hint">Podaj rozmiar ekranu</span>
        </div>
        <button class="redetect-btn" id="btn-redetect" aria-label="Wykryj ponownie">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          Wykryj
        </button>
      </div>
    </div>

    <!-- Ruler SVG container — scrollable -->
    <div class="ruler-scroll-area" id="ruler-scroll-area">
      <div class="ruler-track" id="ruler-track">
        <!-- SVG will be injected here -->
      </div>
    </div>

    <!-- Sticky bottom bar: CM / INCH toggle -->
    <div class="ruler-bottom-bar" id="ruler-bottom-bar">
      <div class="unit-toggle">
        <button class="unit-btn active" id="btn-unit-cm" aria-label="Centymetry" aria-pressed="true">CM</button>
        <span class="unit-sep">|</span>
        <button class="unit-btn" id="btn-unit-inch" aria-label="Cale" aria-pressed="false">INCH</button>
      </div>
      <a href="/linijka-do-druku/" class="bottom-link">Linijka do druku</a>
    </div>
  </section>

  <!-- ====== CALIBRATION PANEL (compact) ====== -->
  <section class="section section-alt calibration-panel no-print" id="kalibracja" aria-label="Kalibracja linijki">
    <div class="container">
      <h2>Kalibracja linijki</h2>
      <p>Linijka kalibruje się automatycznie na podstawie Twojego urządzenia. Możesz też skalibrować ręcznie.</p>

      <div class="calibration-grid">
        <!-- Method: Credit Card -->
        <div class="card calibration-card" id="calibration-card">
          <h3>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Kalibracja kartą bankową
          </h3>
          <p>Przyłóż kartę do ekranu i dopasuj rozmiar konturów za pomocą suwaka.</p>
          <div class="calibration-form">
            <div class="card-reference" id="card-reference">
              <div class="card-outline" id="card-outline">
                <span class="card-label">85,6 mm</span>
              </div>
            </div>
            <label for="card-slider" class="input-label">Dopasuj rozmiar karty</label>
            <input
              type="range"
              id="card-slider"
              min="200"
              max="500"
              value="323"
              aria-label="Suwak rozmiaru karty"
            />
            <button class="btn btn-primary" id="btn-calibrate-card" style="margin-top: var(--space-3);">Skalibruj linijkę</button>
          </div>
        </div>

        <!-- Status -->
        <div class="card calibration-card">
          <h3>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            Status kalibracji
          </h3>
          <div id="calibration-status-info">
            <p id="calibration-status-text">Sprawdzanie kalibracji...</p>
          </div>
          <button class="btn btn-sm btn-secondary" id="btn-reset-calibration" style="margin-top: var(--space-3);">Resetuj kalibrację</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== SEO CONTENT ====== -->
  <section class="section seo-content">
    <div class="container seo-container">
      <h2>Czym jest linijka online?</h2>
      <p>
        Linijka online to proste narzędzie, które pozwala mierzyć małe przedmioty bez tradycyjnej linijki. 
        Wystarczy otworzyć stronę na telefonie, tablecie lub komputerze i położyć przedmiot przy skali widocznej na ekranie.
      </p>

      <h2>Jak używać linijki online?</h2>
      <ol class="steps-list">
        <li>
          <span class="step-number">1</span>
          <span>Otwórz stronę na swoim urządzeniu.</span>
        </li>
        <li>
          <span class="step-number">2</span>
          <span>Linijka automatycznie skalibruje się do Twojego ekranu.</span>
        </li>
        <li>
          <span class="step-number">3</span>
          <span>Połóż przedmiot przy skali na ekranie.</span>
        </li>
        <li>
          <span class="step-number">4</span>
          <span>Odczytaj długość w centymetrach lub calach.</span>
        </li>
      </ol>

      <h2>Linijka w telefonie</h2>
      <p>
        Jeśli nie masz pod ręką fizycznej miarki, telefon może działać jako szybka <a href="#linijka">linijka online</a>. 
        Przewiń ekran w dół, aby zobaczyć pełną skalę. Linijka automatycznie rozpoznaje Twoje urządzenie i kalibruje się.
      </p>

      <h2>Centymetr online i miarka cm</h2>
      <p>
        Nasza <a href="#linijka">miarka online</a> pokazuje podziałkę w centymetrach i milimetrach. 
        Możesz też przełączyć na cale. Dzięki temu szybko sprawdzisz długość drobnych przedmiotów, takich jak karta, śruba, biżuteria, opakowanie czy notatnik.
      </p>

      <h2>Linijka online 20 cm i 10 cm</h2>
      <p>
        Na wielu ekranach dostępna jest linijka online 10 cm, 20 cm lub dłuższa. 
        Długość widocznej skali zależy od wielkości ekranu. Przewiń w dół, aby zobaczyć więcej.
      </p>

      <h2>Czy linijka online jest dokładna?</h2>
      <p>
        Linijka online może być bardzo pomocna do szybkich pomiarów, ale jej dokładność zależy od ekranu i <a href="#kalibracja">kalibracji</a>. 
        Do precyzyjnych zastosowań technicznych zawsze warto sprawdzić wynik fizyczną linijką lub suwmiarką.
      </p>

      <div class="seo-cta-row">
        <p>
          Chcesz mieć fizyczną miarkę? Wydrukuj naszą <a href="/linijka-do-druku/">linijkę do druku</a> w formacie A4.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== CONVERSION TABLE ====== -->
  <section class="section section-alt conversion-section" id="tabela-konwersji" aria-label="Tabela konwersji">
    <div class="container">
      <h2>Tabela konwersji: centymetry, milimetry i cale</h2>
      <p>Szybkie przeliczanie popularnych jednostek długości.</p>
      
      <div class="table-wrapper">
        <table aria-label="Tabela konwersji centymetrów, milimetrów i cali">
          <thead>
            <tr>
              <th scope="col">Centymetry</th>
              <th scope="col">Milimetry</th>
              <th scope="col">Cale</th>
            </tr>
          </thead>
          <tbody>
            {conversionData.map((row) => (
              <tr>
                <td>{row.cm} cm</td>
                <td>{row.mm} mm</td>
                <td>{row.inch} cala</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section class="section faq-section" id="faq" aria-label="Najczęściej zadawane pytania">
    <div class="container">
      <h2>Najczęściej zadawane pytania</h2>
      
      <div class="faq-list">
        {faqItems.map((item, i) => (
          <details class="faq-item" id={`faq-${i + 1}`}>
            <summary class="faq-question">
              <span>{item.question}</span>
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ====== HERO ====== */
  .hero-section {
    padding: var(--space-10) 0 var(--space-8);
    background: linear-gradient(180deg, var(--accent-bg) 0%, var(--bg-primary) 100%);
  }

  @media (min-width: 768px) {
    .hero-section {
      padding: var(--space-16) 0 var(--space-12);
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  .hero-text h1 { margin-bottom: var(--space-4); }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    max-width: 50ch;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-bottom: 0;
  }

  .hero-image {
    display: flex;
    justify-content: center;
  }

  .hero-image img {
    width: 100%;
    max-width: 520px;
    height: auto;
    border-radius: var(--radius-lg);
  }

  /* ====== FULL-PAGE RULER ====== */
  .ruler-section {
    position: relative;
    background: #fff;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .ruler-hint {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
  }

  /* Floating device card */
  .ruler-device-card {
    position: absolute;
    top: 56px;
    left: 80px;
    z-index: 10;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--space-4);
    min-width: 240px;
    max-width: 320px;
  }

  @media (max-width: 500px) {
    .ruler-device-card {
      left: 70px;
      right: var(--space-3);
      min-width: auto;
    }
  }

  .device-card-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    font-size: 0.875rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  .device-diagonal {
    color: var(--text-tertiary);
    font-weight: 400;
  }

  .device-card-body {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .device-screen-input {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .screen-size-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    min-width: 72px;
  }

  .screen-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .screen-value-input {
    width: 60px;
    border: none;
    background: transparent;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    padding: 0;
    -moz-appearance: textfield;
  }

  .screen-value-input::-webkit-inner-spin-button,
  .screen-value-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .screen-value-input:focus {
    outline: none;
    color: var(--accent);
  }

  .screen-unit {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .device-hint {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  .redetect-btn {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--transition-fast);
    margin-top: var(--space-2);
  }

  .redetect-btn:hover {
    background: var(--accent-bg);
    border-color: var(--accent-lighter);
  }

  /* Ruler scroll area */
  .ruler-scroll-area {
    overflow-y: auto;
    overflow-x: hidden;
    max-height: 80vh;
    min-height: 400px;
    position: relative;
    -webkit-overflow-scrolling: touch;
  }

  .ruler-track {
    position: relative;
  }

  .ruler-track :global(svg) {
    display: block;
  }

  /* Sticky bottom bar */
  .ruler-bottom-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
  }

  .unit-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .unit-btn {
    background: none;
    border: none;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    letter-spacing: 0.05em;
  }

  .unit-btn:hover {
    color: var(--accent);
  }

  .unit-btn.active {
    color: var(--accent);
    background: var(--accent-bg);
  }

  .unit-sep {
    color: var(--border-dark);
    font-size: 0.875rem;
  }

  .bottom-link {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .bottom-link:hover {
    color: var(--accent);
  }

  /* ====== CALIBRATION ====== */
  .calibration-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }

  @media (min-width: 768px) {
    .calibration-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .calibration-card h3 {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: 0;
    margin-bottom: var(--space-3);
  }

  .calibration-card p {
    font-size: 0.9375rem;
    margin-bottom: var(--space-4);
  }

  .card-reference {
    display: flex;
    justify-content: center;
    padding: var(--space-4) 0;
    margin-bottom: var(--space-4);
