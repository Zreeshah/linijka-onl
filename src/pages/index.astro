<script>
  import { initRuler } from '../scripts/ruler';
  import { detectDevice, onOrientationChange } from '../scripts/device-detect';
  import {
    loadCalibration,
    resetCalibration,
    calibrateByDiagonal,
    calibrateByCard,
    getCurrentPxPerMm,
  } from '../scripts/calibration';

  // --- Ruler Initialization ---
  const container = document.getElementById('ruler-container') as HTMLElement;
  const rulerInfo = document.getElementById('ruler-info') as HTMLElement;

  function updateRulerInfo() {
    const device = detectDevice();
    const pxPerMm = getCurrentPxPerMm();
    const cal = loadCalibration();
    let deviceLabel = device.isMobile ? 'Telefon' : device.isTablet ? 'Tablet' : 'Komputer';
    let orientLabel = device.isLandscape ? 'poziomo' : 'pionowo';
    let calLabel = cal ? ` · Skalibrowano` : '';
    rulerInfo.textContent = `${deviceLabel} · ${orientLabel}${calLabel}`;
  }

  function renderRuler(orientation?: 'horizontal' | 'vertical') {
    if (container) {
      initRuler(container, orientation);
      updateRulerInfo();
    }
  }

  // Initial render
  renderRuler();

  // Re-render on orientation change
  onOrientationChange(() => {
    renderRuler();
  });

  // --- Ruler Controls ---
  document.getElementById('btn-horizontal')?.addEventListener('click', () => {
    renderRuler('horizontal');
  });

  document.getElementById('btn-vertical')?.addEventListener('click', () => {
    renderRuler('vertical');
  });

  document.getElementById('btn-fullscreen')?.addEventListener('click', () => {
    const el = document.documentElement;
    if (!document.fullscreenElement) {
      el.requestFullscreen?.();
    } else {
      document.exitFullscreen?.();
    }
  });

  document.getElementById('btn-calibrate-scroll')?.addEventListener('click', () => {
    document.getElementById('kalibracja')?.scrollIntoView({ behavior: 'smooth' });
  });

  // --- Calibration: Diagonal ---
  document.getElementById('btn-calibrate-diagonal')?.addEventListener('click', () => {
    const input = document.getElementById('diagonal-input') as HTMLInputElement;
    const value = parseFloat(input.value);
    if (!value || value < 3 || value > 100) {
      input.focus();
      return;
    }
    calibrateByDiagonal(value);
    showCalibrationStatus();
    renderRuler();
  });

  // --- Calibration: Credit Card ---
  const cardOutline = document.getElementById('card-outline') as HTMLElement;
  const cardSlider = document.getElementById('card-slider') as HTMLInputElement;
  
  if (cardSlider && cardOutline) {
    cardSlider.addEventListener('input', () => {
      const width = parseInt(cardSlider.value);
      cardOutline.style.width = width + 'px';
      // Maintain credit card aspect ratio (85.6mm × 53.98mm)
      cardOutline.style.height = Math.round(width * (53.98 / 85.6)) + 'px';
    });
  }

  document.getElementById('btn-calibrate-card')?.addEventListener('click', () => {
    if (cardSlider) {
      const cardWidthPx = parseInt(cardSlider.value);
      calibrateByCard(cardWidthPx);
      showCalibrationStatus();
      renderRuler();
    }
  });

  // --- Calibration Status ---
  function showCalibrationStatus() {
    const statusEl = document.getElementById('calibration-status');
    if (statusEl) {
      statusEl.style.display = 'flex';
    }
  }

  // Check for existing calibration on load
  if (loadCalibration()) {
    showCalibrationStatus();
  }

  document.getElementById('btn-reset-calibration')?.addEventListener('click', () => {
    resetCalibration();
    const statusEl = document.getElementById('calibration-status');
    if (statusEl) {
      statusEl.style.display = 'none';
    }
    renderRuler();
  });
</script>
