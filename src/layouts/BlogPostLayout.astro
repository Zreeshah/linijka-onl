---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date | string;
  heroImage: string;
  imageAlt?: string;
  ogTitle?: string;
  ogDescription?: string;
  slug: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
  relatedPosts?: Array<{ slug: string; title: string; heroImage: string }>;
}

const {
  title,
  description,
  pubDate,
  heroImage,
  imageAlt = '',
  ogTitle,
  ogDescription,
  slug,
  headings,
  relatedPosts = []
} = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Generate dynamic JSON-LD article schema
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": `https://linijka.onl${heroImage}`,
  "author": {
    "@type": "Organization",
    "name": "Redakcja"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Linijka Online",
    "logo": {
      "@type": "ImageObject",
      "url": "https://linijka.onl/favicon.svg"
    }
  },
  "datePublished": "2026-06-07",
  "dateModified": "2026-06-07",
  "inLanguage": "pl-PL",
  "mainEntityOfPage": `https://linijka.onl/blog/${slug}/`
});

// Filter headings for the Table of Contents (H2 and H3 headings)
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout
  title={`${title} | Blog Linijka.onl`}
  description={description}
  canonicalUrl={`https://linijka.onl/blog/${slug}/`}
  ogImage={heroImage}
  schemaMarkup={articleSchema}
>
  <div class="blog-post-container container">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs no-print" aria-label="Ścieżka powrotu">
      <ol role="list">
        <li><a href="/">Strona główna</a></li>
        <li><svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></li>
        <li><a href="/blog/">Blog</a></li>
        <li><svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <div class="blog-grid">
      <!-- Main Article -->
      <article class="blog-main">
        <header class="blog-header">
          <div class="blog-meta">
            <span class="blog-category">Poradnik Pomiaru</span>
            <span class="meta-dot">&bull;</span>
            <time datetime={new Date(pubDate).toISOString()}>{formattedDate}</time>
            <span class="meta-dot">&bull;</span>
            <span class="author-label">Autor: Redakcja</span>
          </div>
          <h1 class="blog-title">{title}</h1>
          <p class="blog-lead">{description}</p>
          
          <div class="blog-hero-wrapper">
            <img class="blog-hero-image" src={heroImage} alt={imageAlt || title} />
          </div>
        </header>

        <!-- Dynamic Content Slot -->
        <div class="blog-content">
          <slot />
        </div>

        <!-- Call to Action Section -->
        <section class="blog-cta no-print">
          <div class="cta-card">
            <h3>Potrzebujesz dokładnego pomiaru?</h3>
            <p>Skorzystaj z naszej bezpłatnej, w pełni skalibrowanej linijki online, która dostosowuje się automatycznie do Twojego ekranu.</p>
            <a href="/" class="btn btn-primary">Uruchom linijkę online 1:1</a>
          </div>
        </section>
      </article>

      <!-- Sidebar -->
      <aside class="blog-sidebar no-print">
        <!-- Table of Contents -->
        {tocHeadings.length > 0 && (
          <div class="toc-card sticky-sidebar">
            <h2 class="toc-title">Spis treści</h2>
            <nav class="toc-nav">
              <ul>
                {tocHeadings.map((heading) => (
                  <li class={`toc-depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        )}
      </aside>
    </div>

    <!-- Related Articles -->
    {relatedPosts.length > 0 && (
      <section class="related-posts-section no-print">
        <h2 class="section-title">Polecane artykuły</h2>
        <div class="related-grid">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="related-card">
              <div class="related-img-wrapper">
                <img src={post.heroImage} alt={post.title} />
              </div>
              <div class="related-body">
                <h3>{post.title}</h3>
                <span class="related-more">Czytaj dalej &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
